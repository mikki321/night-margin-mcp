# Kopioi tiedostoksi .env ja täytä omat arvosi: cp .env.example .env
WHEELHOUSE_API_KEY=          # oma Wheelhouse-avaimesi
COST_SOURCE=manual           # manual | csv | cleanhub
AVG_TURNOVER_COST=70         # € per vaihto (manual-tila ja csv-fallback)
COST_TIERS=                  # valinnainen: "1br:55,2br:70,3br:95"
CSV_PATH=                    # csv-tila: polku kustannus-CSV:hen
CLEANHUB_API_URL=            # cleanhub-tila
CLEANHUB_TOKEN=
MIN_MARGIN=25                # aukkoyölattian minimikate €
