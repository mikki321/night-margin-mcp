# Copy to .env and fill in your own values: cp .env.example .env
WHEELHOUSE_API_KEY=          # your own Wheelhouse key
WHEELHOUSE_CHANNEL=          # optional read-call override; by default each listing's own channel field is used (writes always use the listing's own channel)
COST_SOURCE=manual           # manual | csv | cleanhub
AVG_TURNOVER_COST=70         # € per turnover (manual mode and CSV fallback)
COST_TIERS=                  # optional: "1br:55,2br:70,3br:95"
CSV_PATH=                    # csv mode: path to the cost CSV
CLEANHUB_API_URL=            # cleanhub mode
CLEANHUB_TOKEN=
MIN_MARGIN=25                # minimum margin € for the gap-night floor
NM_STATE_DIR=                # local state dir for the decision log + monthly targets; default ~/.night-margin
