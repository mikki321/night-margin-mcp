{
  "name": "night-margin-mcp",
  "version": "0.2.0",
  "description": "Margin engine for short-term rentals — net per available night, after turnover costs. MCP server for Claude.",
  "license": "MIT",
  "keywords": [
    "mcp",
    "mcp-server",
    "wheelhouse",
    "revenue-management",
    "short-term-rental",
    "vacation-rental"
  ],
  "type": "module",
  "bin": {
    "night-margin-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "dev:mcp": "tsx src/index.ts",
    "build:mcp": "tsc -p tsconfig.mcp.json",
    "test": "vitest run",
    "prepare": "npm run build:mcp",
    "prepublishOnly": "npm run build:mcp && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "csv-parse": "^5.5.0",
    "lucide-react": "^1.25.0",
    "next": "^16.2.11",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "recharts": "^3.10.0",
    "swr": "^2.4.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.21",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikki321/night-margin-mcp.git"
  },
  "homepage": "https://github.com/mikki321/night-margin-mcp#readme",
  "bugs": {
    "url": "https://github.com/mikki321/night-margin-mcp/issues"
  }
}
